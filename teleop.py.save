from curtsies import Input
from motor_driver import RobotController
from launch_motor_driver import LaunchController # New import

# Initialize both controllers
bot = RobotController()
launcher = LaunchController()

speed = 0.4 
move_duration = 0.5 

print("--- Dual Controller Active ---")
print("W/A/S/D : Move Robot")
print("Space   : Ramp Launcher up to 20%")
print("'n'     : Ramp Launcher down to 0%")
print("'q'     : Quit all")

def main():
    with Input(keynames='curtsies') as input_generator:
        for key in input_generator:
            # --- Drivetrain Controls ---
            if key == 'w':
                print("Moving forward...")
                bot.move_forward(duration=move_duration, speed=speed)
            elif key == 's':
                print("Moving backward...")
                bot.move_backward(duration=move_duration, speed=speed)
            elif key == 'a':
                print("Turning left...")
                bot.turn_left(duration=move_duration, speed=speed)
            elif key == 'd':
                print("Turning right...")
                bot.turn_right(duration=move_duration, speed=speed)

            # --- Launcher Controls ---
            elif key == ' ':
                print("Ramping up launcher (20%)...")
                launcher.ramp_to(0.2)
            
            elif key == 'n':
                print("Ramping down launcher...")
                launcher.ramp_to(0.0)

            # --- Exit ---
            elif key == 'q':
                print("Stopping everything and exiting...")
                bot.stop()
                launcher.emergency_stop()
                break

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        bot.stop()
        launcher.emergency_stop()
